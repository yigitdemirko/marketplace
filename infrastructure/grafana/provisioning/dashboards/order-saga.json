{
  "uid": "order-saga",
  "title": "Marketplace — Order Saga & Business",
  "description": "Order lifecycle, payment outcomes, stock reservations, error logs",
  "tags": ["marketplace", "business"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "row",
      "title": "📦 Order Lifecycle",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2, "type": "timeseries",
      "title": "Order Creation Rate",
      "description": "POST /api/v1/orders — new orders per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job=\"order-service\",uri=~\"/api/v1/orders\",method=\"POST\",status=~\"2..\"}[$__rate_interval]))", "legendFormat": "orders created / sec" }]
    },
    {
      "id": 3, "type": "timeseries",
      "title": "Order Cancellation Rate",
      "description": "DELETE or PATCH cancel endpoint calls",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job=\"order-service\",uri=~\".*/cancel\",status=~\"2..\"}[$__rate_interval]))", "legendFormat": "orders cancelled / sec" }]
    },
    {
      "id": 4, "type": "timeseries",
      "title": "Order Validation Errors",
      "description": "4xx on POST /orders — product invalid, insufficient stock, etc.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "mode": "fixed", "fixedColor": "red" } } },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job=\"order-service\",method=\"POST\",status=~\"4..\"}[$__rate_interval]))", "legendFormat": "order errors / sec" }]
    },
    {
      "id": 5, "type": "row",
      "title": "💳 Payment Outcomes",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 6, "type": "timeseries",
      "title": "Payment Success vs Failure",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 5 } }, "overrides": [{ "matcher": { "id": "byName", "options": "success" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }, { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }] },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"payment-service\",method=\"POST\",status=\"200\"}[$__rate_interval]))", "legendFormat": "success" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"payment-service\",method=\"POST\",status=~\"4..|5..\"}[$__rate_interval]))", "legendFormat": "failure" }
      ]
    },
    {
      "id": 7, "type": "timeseries",
      "title": "Payment Latency (Iyzico round-trip)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"payment-service\",method=\"POST\"}[$__rate_interval])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"payment-service\",method=\"POST\"}[$__rate_interval])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"payment-service\",method=\"POST\"}[$__rate_interval])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 8, "type": "row",
      "title": "🏪 Stock & Inventory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "id": 9, "type": "timeseries",
      "title": "Stock Validation Calls",
      "description": "POST /api/v1/products/validate from order-service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"catalog-service\",uri=~\".*/validate\",status=\"200\"}[$__rate_interval]))", "legendFormat": "valid" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"catalog-service\",uri=~\".*/validate\",status=~\"4..\"}[$__rate_interval]))", "legendFormat": "rejected (out of stock / invalid)" }
      ]
    },
    {
      "id": 10, "type": "timeseries",
      "title": "Product Catalog — write traffic",
      "description": "Product creates / updates from sellers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"catalog-service\",method=\"POST\",status=\"200\"}[$__rate_interval]))", "legendFormat": "POST (create/batch)" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"catalog-service\",method=\"PUT\",status=\"200\"}[$__rate_interval]))", "legendFormat": "PUT (update)" }
      ]
    },
    {
      "id": 11, "type": "row",
      "title": "📋 Live Error Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false
    },
    {
      "id": 12, "type": "logs",
      "title": "ERROR & WARN logs — all services",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 27 },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": false },
      "targets": [{ "expr": "{service=~\"order-service|payment-service|catalog-service|inventory-service|user-service\"} |= `` | json | level =~ `(ERROR|WARN)`", "legendFormat": "" }]
    },
    {
      "id": 13, "type": "row",
      "title": "🔐 Auth Events",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "collapsed": false
    },
    {
      "id": 14, "type": "logs",
      "title": "Login / Register Events",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "sortOrder": "Descending" },
      "targets": [{ "expr": "{service=\"user-service\"} |= `` | json | message =~ `(Login|register|Register|logged)`", "legendFormat": "" }]
    }
  ]
}
