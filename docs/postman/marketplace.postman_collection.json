              "raw": "[\n  {\n    \"name\": \"Product A\",\n    \"description\": \"Description A\",\n    \"price\": 199.00,\n    \"stock\": 10,\n    \"category\": \"ELECTRONICS\",\n    \"brand\": \"BrandA\"\n  },\n  {\n    \"name\": \"Product B\",\n    \"description\": \"Description B\",\n    \"price\": 299.00,\n    \"stock\": 5,\n    \"category\": \"ELECTRONICS\",\n    \"brand\": \"BrandB\"\n  }\n]"
