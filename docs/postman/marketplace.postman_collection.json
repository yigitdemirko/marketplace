{
  "info": {
    "name": "Marketplace Platform",
    "description": "All REST endpoints for the Marketplace microservices platform.\n\nAll requests go through the API Gateway on `{{baseUrl}}` (default `http://localhost:8080`).\n\n**Auth model:** Cookie-based.\n- `POST /api/v1/auth/buyer/login` (or seller/register variants) sets `access_token` and `refresh_token` httpOnly cookies.\n- Postman's cookie jar will pick them up automatically when `withCredentials` is enabled (default).\n- For seller-only endpoints, log in with a seller account first.\n\n**Server-authoritative fields:** Order item `unitPrice` and Payment `amount` are ignored by the server — values come from catalog/order respectively.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "buyerEmail", "value": "buyer1@example.com", "type": "string" },
    { "key": "buyerPassword", "value": "password123", "type": "string" },
    { "key": "sellerEmail", "value": "seller1@example.com", "type": "string" },
    { "key": "sellerPassword", "value": "password123", "type": "string" },
    { "key": "productId", "value": "REPLACE_WITH_PRODUCT_ID", "type": "string" },
    { "key": "sellerId", "value": "REPLACE_WITH_SELLER_ID", "type": "string" },
    { "key": "userId", "value": "REPLACE_WITH_USER_ID", "type": "string" },
    { "key": "orderId", "value": "REPLACE_WITH_ORDER_ID", "type": "string" },
    { "key": "addressId", "value": "REPLACE_WITH_ADDRESS_ID", "type": "string" },
    { "key": "cardId", "value": "REPLACE_WITH_CARD_ID", "type": "string" },
    { "key": "categoryId", "value": "ELECTRONICS", "type": "string" },
    { "key": "notificationId", "value": "REPLACE_WITH_NOTIFICATION_ID", "type": "string" },
    { "key": "jobId", "value": "REPLACE_WITH_JOB_ID", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth (user-service)",
      "item": [
        {
          "name": "Register Buyer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{buyerEmail}}\",\n  \"password\": \"{{buyerPassword}}\",\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/buyer/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "buyer", "register"] }
          }
        },
        {
          "name": "Register Seller",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sellerEmail}}\",\n  \"password\": \"{{sellerPassword}}\",\n  \"storeName\": \"Acme Store\",\n  \"taxNumber\": \"1234567890\",\n  \"phone\": \"+905551112233\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/seller/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "seller", "register"] }
          }
        },
        {
          "name": "Login (generic)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{buyerEmail}}\",\n  \"password\": \"{{buyerPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          }
        },
        {
          "name": "Login (buyer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{buyerEmail}}\",\n  \"password\": \"{{buyerPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/buyer/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "buyer", "login"] }
          }
        },
        {
          "name": "Login (seller)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sellerEmail}}\",\n  \"password\": \"{{sellerPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/seller/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "seller", "login"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "refresh"] },
            "description": "Reads `refresh_token` cookie, rotates the token pair."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"] }
          }
        },
        {
          "name": "Logout All Sessions",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout-all", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout-all"] }
          }
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "me"] }
          }
        }
      ]
    },
