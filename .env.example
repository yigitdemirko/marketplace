# Copy this file to .env and fill in the values before running docker-compose.

# ── Database ──────────────────────────────────────────────────────────────────
DB_USERNAME=
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=

# ── Iyzico ────────────────────────────────────────────────────────────────────
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
# Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords (16-char string, no spaces).
# Use the App Password as MAIL_PASSWORD — your account password will be rejected.
# Gmail forces the From header to equal MAIL_USERNAME.
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://bilbos-shop.com
SELLER_URL=https://seller.bilbos-shop.com
# Base URL Swagger "Try it out" sends requests to (no /api suffix — paths already start with /api/v1/)
# Swagger "Try it out" base URL — no /api suffix, paths already start with /api/v1/
# With nginx rewrite: api.bilbos-shop.com/v1/... → gateway /api/v1/...
API_SERVER_URL=https://api.bilbos-shop.com
