{
  "uid": "marketplace-overview",
  "title": "Marketplace — Overview",
  "description": "Service health, traffic, latency, JVM and system metrics",
  "tags": ["marketplace"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🟢 Service Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "All Services",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "horizontal",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } },
            { "type": "special", "options": { "match": "null", "result": { "text": "N/A", "color": "orange" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        { "expr": "up{job=~\"api-gateway|user-service|catalog-service|order-service|payment-service|search-service|notification-service|feed-ingestion-service|inventory-service|basket-service\"}", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 3,
      "type": "row",
      "title": "📊 Traffic",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Requests / sec — per service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2 }, "unit": "reqps" } },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"api-gateway\"}[$__rate_interval]))", "legendFormat": "api-gateway" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"order-service\"}[$__rate_interval]))", "legendFormat": "order-service" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"payment-service\"}[$__rate_interval]))", "legendFormat": "payment-service" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"catalog-service\"}[$__rate_interval]))", "legendFormat": "catalog-service" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"inventory-service\"}[$__rate_interval]))", "legendFormat": "inventory-service" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"basket-service\"}[$__rate_interval]))", "legendFormat": "basket-service" },
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"user-service\"}[$__rate_interval]))", "legendFormat": "user-service" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "5xx Error Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "custom": { "lineWidth": 2 }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] }, "color": { "mode": "fixed", "fixedColor": "red" } } },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",job=\"order-service\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"order-service\"}[$__rate_interval])),0.001)", "legendFormat": "order-service" },
        { "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",job=\"payment-service\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"payment-service\"}[$__rate_interval])),0.001)", "legendFormat": "payment-service" },
        { "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",job=\"catalog-service\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"catalog-service\"}[$__rate_interval])),0.001)", "legendFormat": "catalog-service" },
        { "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",job=\"inventory-service\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"inventory-service\"}[$__rate_interval])),0.001)", "legendFormat": "inventory-service" },
        { "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",job=\"basket-service\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"basket-service\"}[$__rate_interval])),0.001)", "legendFormat": "basket-service" },
        { "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\",job=\"user-service\"}[$__rate_interval])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"user-service\"}[$__rate_interval])),0.001)", "legendFormat": "user-service" }
      ]
    },
    {
      "id": 6,
      "type": "row",
      "title": "⏱ Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "order-service — p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 15 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"order-service\"}[$__rate_interval])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"order-service\"}[$__rate_interval])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"order-service\"}[$__rate_interval])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "payment-service — p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 15 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"payment-service\"}[$__rate_interval])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"payment-service\"}[$__rate_interval])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"payment-service\"}[$__rate_interval])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "catalog-service — p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 15 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"catalog-service\"}[$__rate_interval])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"catalog-service\"}[$__rate_interval])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"catalog-service\"}[$__rate_interval])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "💻 JVM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Heap Used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 23 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) by (job)", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "GC Pause Time (per second)",
      "description": "How much wall-clock time is spent in garbage collection per service. Sustained >50ms/s suggests memory pressure.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 23 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "sum(rate(jvm_gc_pause_seconds_sum[$__rate_interval])) by (job)", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Live Threads",
      "description": "Number of live JVM threads per service. Steadily climbing = thread leak.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 23 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "jvm_threads_live_threads", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "🖥️ System",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "collapsed": false
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "CPU Usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 31 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "process_cpu_usage", "legendFormat": "{{job}}" }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "DB Connection Pool — Active",
      "description": "HikariCP active (in-use) connections per JDBC service. Approaching pool max means saturation.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 31 },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } },
      "targets": [
        { "expr": "hikaricp_connections_active", "legendFormat": "{{job}} active" },
        { "expr": "hikaricp_connections_max", "legendFormat": "{{job}} pool max" }
      ]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Process Uptime",
      "description": "Time since each process started. Drops to 0 on restart.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 31 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "horizontal",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 60 }, { "color": "green", "value": 300 }] },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        { "expr": "process_uptime_seconds", "legendFormat": "{{job}}" }
      ]
    }
  ]
}
